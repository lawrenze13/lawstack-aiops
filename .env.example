# --- Auth.js v5 ---
# openssl rand -hex 32
AUTH_SECRET=
# Google Cloud OAuth client
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Set to your prod URL in production; omit in dev
# AUTH_URL=https://aiops.multiportal.io

# --- Domain restriction ---
# signIn callback rejects emails not ending in this domain.
ALLOWED_EMAIL_DOMAIN=multiportal.io

# --- Jira Cloud REST v3 ---
JIRA_BASE_URL=https://your-workspace.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=

# --- GitHub (Phases 3+: Approve & PR) ---
# Fine-grained PAT with Contents:rw + Pull requests:rw on the target repo.
GH_TOKEN=

# --- Anthropic / Claude CLI (Phases 2+: agent runner) ---
# Either is fine; CLAUDE_CODE_OAUTH_TOKEN is preferred if you have a Claude Pro/Max plan.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# --- Worktree root (Phase 2+) ---
# Persistent path, NOT /tmp. The systemd service user must own this dir.
WORKTREE_ROOT=/var/aiops/worktrees
# Base repo to checkout worktrees from
BASE_REPO=/var/www/lawrenze.multiportal.io

# --- DB ---
# Override only if you want a non-default location.
# DATABASE_URL=./data/app.db
